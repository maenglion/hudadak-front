<?xml version="1.0" encoding="utf-8"?>
<!--
  위젯 크기: 260×168dp
  좌우 패딩: 18dp | 상단: 16dp | 하단: 23dp
  배경: #242526 (다크모드 card-color)
  등급 텍스트: 흰색, 등급 배경 뱃지에 색상 적용 (KT에서 setBackgroundColor)
  수치+단위: 회색 (#80FFFFFF)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#242526"
    android:paddingLeft="18dp"
    android:paddingRight="18dp"
    android:paddingTop="16dp"
    android:paddingBottom="23dp">

    <!-- 상단 행: 지역명(좌) + 소스라벨(우) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_region"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="위치 확인 중..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_source_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="실측(WAQI)"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />
    </RelativeLayout>

    <!-- 현재시간 (지역명 아래 2dp) -->
    <TextView
        android:id="@+id/widget_updated_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="현재시간: --:--"
        android:textColor="#80FFFFFF"
        android:textSize="11sp" />

    <!-- PM10 박스 (현재시간 기준 22dp 아래) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="미세먼지"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_pm10_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나쁨"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/widget_pm10_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- µg/m³"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/widget_pm10_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_pm10"
            android:max="200"
            android:progress="0" />
    </LinearLayout>

    <!-- PM25 박스 (PM10 기준 24dp 아래) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="초미세먼지"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_pm25_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="매우나쁨"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/widget_pm25_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- µg/m³"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/widget_pm25_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_pm25"
            android:max="150"
            android:progress="0" />
    </LinearLayout>

</LinearLayout>
