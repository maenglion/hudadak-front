<?xml version="1.0" encoding="utf-8"?>
<!--
  위젯 크기: 260×168dp
  좌우 패딩: 18dp | 상단: 16dp | 하단: 23dp
  배경: #242526 (다크모드 card-color)
  등급 텍스트: 등급 색상, 박스 없음
  바: 등급별 4개 ProgressBar (visibility로 전환)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#242526"
    android:paddingLeft="18dp"
    android:paddingRight="18dp"
    android:paddingTop="16dp"
    android:paddingBottom="23dp">

    <!-- 상단 행: 지역명(좌) + 소스라벨(우) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_region"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="위치 확인 중..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_source_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="실측(WAQI)"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />
    </RelativeLayout>

    <!-- 현재시간 -->
    <TextView
        android:id="@+id/widget_updated_at"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="현재시간: --:--"
        android:textColor="#80FFFFFF"
        android:textSize="11sp" />

    <!-- PM10 박스 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="미세먼지"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_pm10_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나쁨"
                    android:textColor="#FFF6AA5C"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/widget_pm10_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- µg/m³"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- PM10 바 4종 (등급에 따라 하나만 VISIBLE) -->
        <ProgressBar android:id="@+id/widget_pm10_bar_good"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_good"
            android:max="200" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm10_bar_normal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_normal"
            android:max="200" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm10_bar_bad"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_bad"
            android:max="200" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm10_bar_verybad"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_verybad"
            android:max="200" android:progress="0" android:visibility="gone"/>
    </LinearLayout>

    <!-- PM25 박스 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="초미세먼지"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_pm25_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="매우나쁨"
                    android:textColor="#FFC75959"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/widget_pm25_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- µg/m³"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- PM25 바 4종 -->
        <ProgressBar android:id="@+id/widget_pm25_bar_good"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_good"
            android:max="150" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm25_bar_normal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_normal"
            android:max="150" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm25_bar_bad"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_bad"
            android:max="150" android:progress="0" android:visibility="gone"/>
        <ProgressBar android:id="@+id/widget_pm25_bar_verybad"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressDrawable="@drawable/widget_progress_verybad"
            android:max="150" android:progress="0" android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>
